{
  "name": "ams-dapp-backend",
  "version": "1.0.0",
  "description": "AMS DApp backend — Node/Express API + Truffle workspace for the CN6035 attendance management DApp.",
  "main": "index.js",
  "scripts": {
    "dev": "NODE_ENV=dev nodemon index.js",
    "start": "NODE_ENV=prod node index.js",
    "format": "prettier \"./**/*.{js,html,json}\" --write",
    "lint": "eslint \"./**/*.js\"",
    "test": "mocha tests/v1/test --exit",
    "migrate": "truffle migrate --reset",
    "migrate:full": "truffle migrate --reset && node scripts/sync-contract-addrs.js",
    "compile": "truffle compile",
    "seed": "node scripts/seed_users.js && node scripts/seed_attendance.js 2414204 5",
    "seed:users": "node scripts/seed_users.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Amrindergithub/ams-backend.git"
  },
  "keywords": [
    "attendance",
    "blockchain",
    "ethereum",
    "truffle",
    "ganache",
    "nft",
    "cn6035"
  ],
  "author": "Amrinder Bhullar",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Amrindergithub/ams-backend/issues"
  },
  "homepage": "https://github.com/Amrindergithub/ams-backend#readme",
  "devDependencies": {
    "chai": "^4.5.0",
    "chai-http": "^4.3.0",
    "eslint": "^7.6.0",
    "eslint-config-prettier": "^6.11.0",
    "ethers": "^5.8.0",
    "mocha": "^8.1.1",
    "nodemon": "^2.0.4",
    "prettier": "^2.2.0"
  },
  "dependencies": {
    "@hapi/joi": "^17.1.1",
    "@sendgrid/mail": "^7.4.0",
    "axios": "^0.21.1",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.19.0",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "dotenv": "^8.2.0",
    "express": "^4.17.1",
    "generate-password": "^1.6.0",
    "helmet": "^4.2.0",
    "jsonwebtoken": "^8.5.1",
    "moment": "^2.29.1",
    "mongoose": "^5.11.7",
    "multer": "^1.4.2",
    "nodemailer": "^6.4.16",
    "otp-generator": "^1.1.0",
    "pug": "^3.0.1",
    "swagger-ui-express": "^4.1.5",
    "truffle": "^5.11.5",
    "yamljs": "^0.3.0"
  }
}
