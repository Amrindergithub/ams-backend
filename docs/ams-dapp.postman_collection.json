{
  "info": {
    "name": "AMS DApp — Phase 1 (CN6035)",
    "_postman_id": "ams-dapp-phase1",
    "description": "Minimal end-to-end flow for the AMS DApp web API (baseUrl :5001). Import alongside `docs/ams-dapp.postman_collection.json` and select the \"AMS Local\" environment (or override `baseUrl` in-request).\n\nOrder:\n1. Auth → admin login → capture accessToken\n2. Session → create → capture qrToken\n3. Auth → student login\n4. Session → check-in (student)\n5. Attendance → verify hash\n6. NFT → mint / list / certificate-by-id\n\nReads `{{baseUrl}}`, `{{adminToken}}`, `{{studentToken}}`, `{{qrToken}}`, `{{studentId}}`, `{{attendanceHash}}`, `{{walletAddress}}` from the collection/environment variables. Token capture is scripted in the Tests tab of each login request.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5001/api/v1" },
    { "key": "adminEmail", "value": "lecturer@uel.ac.uk" },
    { "key": "adminPassword", "value": "Admin123!" },
    { "key": "studentEmail", "value": "u2414204@uel.ac.uk" },
    { "key": "studentPassword", "value": "Student123!" },
    { "key": "studentId", "value": "u2414204" },
    { "key": "walletAddress", "value": "0x82d9B534dd4620906ABCe7706244dDb1960D8b49" },
    { "key": "courseId", "value": "CN6035" },
    { "key": "adminToken", "value": "" },
    { "key": "studentToken", "value": "" },
    { "key": "qrToken", "value": "" },
    { "key": "attendanceHash", "value": "" }
  ],
  "item": [
    {
      "name": "Auth — admin login",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "url": { "raw": "{{baseUrl}}/auth/login", "host": [ "{{baseUrl}}" ], "path": [ "auth", "login" ] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const body = pm.response.json();",
              "if (body && body.data && body.data.accessToken) {",
              "  pm.collectionVariables.set('adminToken', body.data.accessToken);",
              "  pm.test('captured admin accessToken', () => pm.expect(body.data.accessToken).to.be.a('string'));",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Auth — student login",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "url": { "raw": "{{baseUrl}}/auth/login", "host": [ "{{baseUrl}}" ], "path": [ "auth", "login" ] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{studentEmail}}\",\n  \"password\": \"{{studentPassword}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const body = pm.response.json();",
              "if (body && body.data && body.data.accessToken) {",
              "  pm.collectionVariables.set('studentToken', body.data.accessToken);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Session — create (admin)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{adminToken}}" }
        ],
        "url": { "raw": "{{baseUrl}}/sessions/create", "host": [ "{{baseUrl}}" ], "path": [ "sessions", "create" ] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"courseId\": \"{{courseId}}\",\n  \"courseName\": \"Blockchain Applications\",\n  \"date\": \"2026-04-22\",\n  \"startTime\": \"10:00\",\n  \"endTime\": \"12:00\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const body = pm.response.json();",
              "if (body && body.data && body.data.qrToken) {",
              "  pm.collectionVariables.set('qrToken', body.data.qrToken);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Session — check-in (student)",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "url": { "raw": "{{baseUrl}}/sessions/check-in", "host": [ "{{baseUrl}}" ], "path": [ "sessions", "check-in" ] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"qrToken\": \"{{qrToken}}\",\n  \"studentId\": \"{{studentId}}\",\n  \"walletAddress\": \"{{walletAddress}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const body = pm.response.json();",
              "if (body && body.data && body.data.attendanceHash) {",
              "  pm.collectionVariables.set('attendanceHash', body.data.attendanceHash);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Session — active sessions (admin)",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{adminToken}}" } ],
        "url": { "raw": "{{baseUrl}}/sessions/all", "host": [ "{{baseUrl}}" ], "path": [ "sessions", "all" ] }
      }
    },
    {
      "name": "Blockchain — verify hash (public)",
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/blockchain/verify/{{attendanceHash}}", "host": [ "{{baseUrl}}" ], "path": [ "blockchain", "verify", "{{attendanceHash}}" ] }
      }
    },
    {
      "name": "NFT — tier stats (public)",
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/nft/tier-stats", "host": [ "{{baseUrl}}" ], "path": [ "nft", "tier-stats" ] }
      }
    },
    {
      "name": "NFT — mint certificate (admin)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{adminToken}}" }
        ],
        "url": { "raw": "{{baseUrl}}/nft/mint", "host": [ "{{baseUrl}}" ], "path": [ "nft", "mint" ] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"studentId\": \"{{studentId}}\"\n}"
        }
      }
    },
    {
      "name": "NFT — certificates by wallet",
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/nft/student/{{walletAddress}}", "host": [ "{{baseUrl}}" ], "path": [ "nft", "student", "{{walletAddress}}" ] }
      }
    },
    {
      "name": "NFT — certificate by tokenId",
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/nft/certificate/0", "host": [ "{{baseUrl}}" ], "path": [ "nft", "certificate", "0" ] }
      }
    }
  ]
}
