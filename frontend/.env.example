# Frontend environment — copy to `.env` (or `.env.local`) and fill in.
# CRA only exposes variables prefixed with REACT_APP_ to the client bundle.

# Backend API base URL. The same bundle can be pointed at a staging /
# deployed API by overriding this — no source change required.
REACT_APP_API_BASE_URL=http://localhost:5001/api/v1

# JSON-RPC endpoint of the chain backing the DApp (Ganache in dev).
# Used by the Navbar chain-heartbeat poll.
REACT_APP_RPC_URL=http://127.0.0.1:7545

# Deployed NFT attendance-certificate contract address.
# Shown in the sidebar footer pill. Falls back to a truncated placeholder
# when unset (see frontend/src/components/Sidebar.js).
REACT_APP_NFT_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
