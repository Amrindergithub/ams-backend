# GitHub Linguist overrides — keep the language bar honest.
#
# Default: all tracked files count toward language stats.
# Vendor (exclude from stats) only machine-generated or third-party content.

# Compiled Truffle ABI artefacts — generated by `truffle compile`.
backend/build/**           linguist-generated=true

# npm lockfiles — not hand-authored source.
**/package-lock.json       linguist-generated=true

# Force-classify source types so the language bar reflects real authored code.
*.sol                      linguist-detectable=true
*.css                      linguist-detectable=true
*.html                     linguist-detectable=true
