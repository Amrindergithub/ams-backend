#!/usr/bin/env bash
# commit-msg hook — reject AI-attribution trailers and mentions.
# Enable locally with:  git config core.hooksPath .githooks

msg_file="$1"

if grep -iqE "claude|anthropic|chatgpt|openai|copilot|^co-authored-by:.*(noreply@anthropic|noreply@openai)" "$msg_file"; then
    echo "" >&2
    echo "✗ commit-msg hook: AI-attribution trailer or mention blocked." >&2
    echo "  Remove Co-Authored-By / 'Generated with' lines and retry." >&2
    echo "" >&2
    exit 1
fi

exit 0
