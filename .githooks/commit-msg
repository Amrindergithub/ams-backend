#!/usr/bin/env bash
# commit-msg hook — reject unwanted co-author trailers.
# Blocked pattern is base64-encoded so source text contains no literal
# vendor names. Enable locally with:
#     git config core.hooksPath .githooks

msg_file="$1"

# decoded pattern: vendor names + noreply domains to block
BAD_PATTERN=$(printf '%s' 'Y2xhdWRlfGFudGhyb3BpY3xjaGF0Z3B0fG9wZW5haXxjb3BpbG90fG5vcmVwbHlAYW50aHJvcGljfG5vcmVwbHlAb3BlbmFp' | base64 -d 2>/dev/null)

if [ -z "$BAD_PATTERN" ]; then
    # base64 binary missing — fall back to generic co-author audit
    BAD_PATTERN='^Co-Authored-By: '
fi

if grep -iqE "$BAD_PATTERN" "$msg_file"; then
    echo "" >&2
    echo "commit-msg hook: blocked trailer detected." >&2
    echo "  Remove external co-author lines from the commit message." >&2
    echo "" >&2
    exit 1
fi

exit 0
